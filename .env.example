# App
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# Frontend (password reset links)
FRONTEND_URL=http://localhost:5173

# JWT - access token (JSON response)
JWT_ACCESS_SECRET=replace_with_strong_random_access_secret_min_32_chars
JWT_ACCESS_ISSUER=car-backend
JWT_ACCESS_AUDIENCE=car-frontend
JWT_ACCESS_TTL_SECONDS=900

# JWT - refresh token (httpOnly cookie + DB session rotation)
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret_min_32_chars
JWT_REFRESH_ISSUER=car-backend
JWT_REFRESH_AUDIENCE=car-frontend
JWT_REFRESH_TTL_SECONDS=2592000

# Refresh cookie
COOKIE_REFRESH_NAME=refresh_token
COOKIE_SECURE=false
# COOKIE_DOMAIN=localhost

# Password reset
PASSWORD_RESET_TTL_SECONDS=3600

# bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate limits
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_MAX=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX=10

# Brute force (login)
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_SECONDS=900

# Database
DATABASE_URL=postgres://user:password@localhost:5432/car

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_smtp_user
SMTP_PASS=replace_with_smtp_pass
EMAIL_FROM="Car App <no-reply@example.com>"

# Seed admin (bun run db:seed)
SEED_ADMIN_NAME=System Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
